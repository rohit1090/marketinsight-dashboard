# Copy this file to .env and fill in your keys.
# NEVER commit .env — it is in .gitignore.

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# ── SerpAPI ───────────────────────────────────────────────────────────────────
# Get your key at https://serpapi.com/manage-api-key
VITE_SERPAPI_KEY=

# ── Social Blade Matrix API ───────────────────────────────────────────────────
# Sign up free at https://socialblade.com → API Access → get CLIENTID + token
SOCIALBLADE_CLIENT_ID=
SOCIALBLADE_TOKEN=

# ── Firebase ──────────────────────────────────────────────────────────────────
# Find these in Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=